# LLM Provider Configuration
# Default: ollama (free, local, no API key required)
# Options: ollama, openai, gemini
LLM_PROVIDER=ollama

# Model name - can use generic LLM_MODEL or provider-specific:
# LLM_MODEL=model-name  # Generic (works for all providers)
# Or use provider-specific:
# GEMINI_MODEL=gemini-2.0-flash-lite
# OPENAI_MODEL=gpt-4
# OLLAMA_MODEL=llama3:latest

# Request timeout in seconds
LLM_TIMEOUT=600

# Temperature (0.0-2.0)
LLM_TEMPERATURE=0.7

# OpenAI API Key (only required if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-api-key-here

# Gemini API Key (only required if LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your-api-key-here
